];

// ────────────────────────────────────────────────────────────
// HELPERS
// ────────────────────────────────────────────────────────────
function slugify(input: string): string {
  return input
    .toLowerCase()
    .normalize('NFKD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

// ────────────────────────────────────────────────────────────
// PHASE A — Seed taxonomy
// ────────────────────────────────────────────────────────────
async function seedTaxonomy() {
  console.log('🌱 Seeding taxonomy…');

  // L1 first (no parent)
  for (const node of TAXONOMY.filter(n => n.level === 1)) {
    await prisma.category.upsert({
      where: { path: node.path },
      update: { name: node.name, sortOrder: node.sortOrder },
      create: { name: node.name, slug: node.slug, level: node.level, path: node.path, sortOrder: node.sortOrder },
    });
  }

  // L2
  for (const node of TAXONOMY.filter(n => n.level === 2)) {
    const parentPath = node.path.split('/').slice(0, -1).join('/');
    const parent = await prisma.category.findUnique({ where: { path: parentPath } });
    if (!parent) { console.warn(`⚠️  Parent not found for ${node.path}`); continue; }
    await prisma.category.upsert({
      where: { path: node.path },
      update: { name: node.name, sortOrder: node.sortOrder },
      create: { name: node.name, slug: node.slug, level: node.level, path: node.path, sortOrder: node.sortOrder, parentId: parent.id },
    });
  }

  // L3
  for (const node of TAXONOMY.filter(n => n.level === 3)) {
    const parentPath = node.path.split('/').slice(0, -1).join('/');
    const parent = await prisma.category.findUnique({ where: { path: parentPath } });
    if (!parent) { console.warn(`⚠️  Parent not found for ${node.path}`); continue; }
    await prisma.category.upsert({
      where: { path: node.path },
      update: { name: node.name, sortOrder: node.sortOrder },
      create: { name: node.name, slug: node.slug, level: node.level, path: node.path, sortOrder: node.sortOrder, parentId: parent.id },
    });
  }

  console.log(`✅ Taxonomy seeded: ${TAXONOMY.length} nodes`);
}

// ────────────────────────────────────────────────────────────
// PHASE B — Raw feed parse + upsert Products/Variants
// ────────────────────────────────────────────────────────────
type GroupItem = {
  name: string;
  category: string;
  brand: string;
  description: string;
  primaryImg: string;
  gallery: string[];
  externalUrl: string | null;
  sku: string;
  ean: string | null;
  size: string | null;
  color: string | null;
  material: string | null;
  gender: string | null;
  price: number;
  currency: string;
  quantity: number;
  stockStatus: string;
};

async function seedProducts() {
  if (!fs.existsSync(PRODUCTS_TXT_PATH)) {
    console.log('ℹ️  No sample-products.txt found — skipping product seed.');
    return;
  }

  console.log('📦 Seeding products from raw feed…');

  const raw = fs.readFileSync(PRODUCTS_TXT_PATH, 'utf8').trim();
  const dataLines = raw
    .split('\n')
    .map(l => l.trim())
    .filter(l => l.length > 0 && !l.startsWith('HDR|') && !l.startsWith('TRL|'));

  const feedBatchId = `feed-${new Date().toISOString()}`;
  const rawProducts: RawProductInput[] = [];
  const groups = new Map<string, GroupItem[]>();

  for (const line of dataLines) {
    const p = line.split('|');

    const productIdFeed = p[0] || null;
    const name         = p[1] || 'Unnamed product';
    const sku          = p[2] || '';
    const category     = p[3] || 'Uncategorized';
    const externalUrl  = p[5] || null;
    const brand        = p[16] || p[20] || 'Unknown';
    const styleCode    = p[19] || null;
    const longDesc     = p[9] || p[8] || '';
    const price        = parseFloat(p[13]) || 0;
    const stockStatus  = p[22] || '';
    const ean          = p[23] || null;
    const quantity     = parseInt(p[24], 10) || 0;
    const currency     = (p[25] || 'GBP').toUpperCase();
    const primaryImg   = p[6] || '';
    const gallery      = (p[26] || '').split(',').map(u => u.trim()).filter(Boolean);
    const size         = p[30] || null;
    const material     = p[31] || null;
    const color        = p[32] || null;
    const genderRaw    = p[33] || null;

    // resolve murl deeplink
    let productUrl = externalUrl;
    if (externalUrl?.includes('murl=')) {
      try {
        const mu = new URL(externalUrl).searchParams.get('murl');
        if (mu) productUrl = decodeURIComponent(mu);
      } catch { /* keep original */ }
    }

    // --- RawProduct record ---
    const rawProduct = RawProductSchema.parse({
      source: 'AWIN',
      feedBatchId,
      rawData: { productId: p[0], name: p[1], sku: p[2], category: p[3], subcategory: p[4], productUrl: p[5], primaryImage: p[6], shortDescription: p[8], longDescription: p[9], price: p[13], brand: p[16], model: p[19], brandName: p[20], stockStatus: p[22], ean: p[23], quantity: p[24], currency: p[25], galleryImages: p[26], size: p[30], materials: p[31], color: p[32], gender: p[33] },
      sku, styleCode, productIdFeed, ean,
    });
    rawProducts.push(rawProduct);

    // --- Group by styleCode / sku ---
    const key = styleCode || sku || productIdFeed || name;
    if (!groups.has(key)) groups.set(key, []);
    groups.get(key)!.push({ name, category, brand, description: longDesc, primaryImg, gallery, externalUrl: productUrl, sku, ean, size, color, material, gender: genderRaw, price, currency, quantity, stockStatus });
  }

  console.log(`  Parsed ${rawProducts.length} raw lines → ${groups.size} grouped products`);

  // ---- Clear existing catalogue data (keep taxonomy + users/carts) ----
  await prisma.productCategory.deleteMany();
  await prisma.productVariant.deleteMany();
  await prisma.product.deleteMany();
  await prisma.rawProduct.deleteMany();

  // ---- Insert RawProducts ----
  await prisma.rawProduct.createMany({ data: rawProducts, skipDuplicates: true });

  // ---- Create Products + Variants + link to Category ----
  let productCount = 0;
  let variantCount = 0;

  // Build a quick path→id lookup from DB
  const allCats = await prisma.category.findMany({ select: { id: true, path: true } });
  const catByPath = new Map(allCats.map(c => [c.path, c.id]));

  for (const [key, items] of groups.entries()) {
    const base = items[0];

    const images = Array.from(new Set([base.primaryImg, ...items.flatMap(i => i.gallery)].filter(Boolean)));
    const slugBase = slugify(base.name);
    const slug = `${slugBase}-${(key || '').toLowerCase()}`.replace(/-+$/, '');
    const totalStock = items.reduce((s, i) => s + i.quantity, 0);
    const minPrice = Math.min(...items.map(i => i.price).filter(p => p > 0)) || 0;
    const mainCurrency = base.currency || 'GBP';
    const anyActive = items.some(i => i.stockStatus.toLowerCase() === 'in-stock');

    // Aggregate facets from all variants
    const colors    = [...new Set(items.map(i => i.color).filter(Boolean))] as string[];
    const sizes     = [...new Set(items.map(i => i.size).filter(Boolean))] as string[];
    const materials = [...new Set(items.map(i => i.material).filter(Boolean))] as string[];

    // Resolve gender enum
    const gRaw = (base.gender || '').toLowerCase();
    const gender: Gender = gRaw.includes('female') || gRaw === 'women' ? 'FEMALE'
                         : gRaw.includes('male')   || gRaw === 'men'   ? 'MALE'
                         : 'UNISEX';

    const variantsData = items.map(i => ({
      sku: i.sku,
      ean: i.ean,
      size: i.size,
      color: i.color,
      material: i.material,
      price: i.price,
      currency: i.currency,
      inStock: i.stockStatus.toLowerCase() === 'in-stock',
      stockQty: i.quantity,
      imageUrl: i.primaryImg || null,
      images: i.gallery,
      deepLink: i.externalUrl,
      externalId: i.sku,
    }));

    const created = await prisma.product.create({
      data: {
        name: base.name,
        slug,
        brand: base.brand,
        description: base.description,
        images,
        imageUrl: base.primaryImg || null,
        colors,
        sizes,
        materials,
        gender,
        source: 'AWIN',
        externalId: key,
        searchTags: [],
        variants: { create: variantsData },
      },
    });

    // Link to category (find best matching path)
    // Simple mapping: raw category string → closest taxonomy path
    const rawCategoryPath = inferCategoryPath(base.category, base.name, base.gender);
    const catId = catByPath.get(rawCategoryPath);
    if (catId) {
      await prisma.productCategory.create({ data: { productId: created.id, categoryId: catId } });
    } else {
      console.warn(`  ⚠️  No category match for "${base.category}" → "${rawCategoryPath}"`);
    }

    productCount++;
    variantCount += variantsData.length;
  }

  console.log(`✅ Products seeded: ${productCount} products, ${variantCount} variants`);
}

// ────────────────────────────────────────────────────────────
// CATEGORY INFERENCE — maps raw feed categories → taxonomy paths
// Extend this table as you add new sources
// ────────────────────────────────────────────────────────────
function inferCategoryPath(rawCategory: string, name: string, gender: string | null): string {
  const cat = rawCategory.toLowerCase();
  const nm  = name.toLowerCase();
  const isMen = (gender || '').toLowerCase().includes('male') || (gender || '').toLowerCase() === 'men';
  const dept  = isMen ? 'men' : 'women';

  // Shoes (gender-neutral dept)
  if (cat.includes('boot'))                                       return nm.includes('ankle') ? 'shoes/boots/ankle-boots' : nm.includes('knee') ? 'shoes/boots/knee-high-boots' : nm.includes('combat') ? 'shoes/boots/combat-boots' : nm.includes('chelsea') ? 'shoes/boots/chelsea-boots' : 'shoes/boots';
  if (cat.includes('heel') || cat.includes('pump'))              return 'shoes/heels-pumps';
  if (cat.includes('sneaker') || cat.includes('trainer'))        return 'shoes/sneakers-trainers';
  if (cat.includes('sandal'))                                     return 'shoes/sandals';
  if (cat.includes('loafer') || cat.includes('flat'))            return 'shoes/flat-shoes';
  if (cat.includes('shoes') || cat.includes('footwear'))         return 'shoes/boots'; // fallback

  // Bags
  if (cat.includes('shoulder bag'))                              return 'bags/shoulder-bags';
  if (cat.includes('clutch') || cat.includes('evening bag'))     return 'bags/clutch-evening-bags';
  if (cat.includes('backpack'))                                   return 'bags/backpacks';
  if (cat.includes('tote'))                                       return 'bags/shoulder-bags/tote-bags';
  if (cat.includes('crossbody'))                                  return 'bags/shoulder-bags/crossbody-bags';
  if (cat.includes('bag'))                                        return 'bags/shoulder-bags'; // fallback

  // Accessories
  if (cat.includes('jewelry') || cat.includes('jewellery'))      return 'accessories/jewelry';
  if (cat.includes('belt'))                                       return 'accessories/belts';
  if (cat.includes('scarf') || cat.includes('wrap'))             return 'accessories/scarves-wraps';
  if (cat.includes('sunglasses') || cat.includes('eyewear'))     return 'accessories/sunglasses';
  if (cat.includes('watch'))                                      return 'accessories/watches';
  if (cat.includes('wallet') || cat.includes('card'))            return 'accessories/wallets-card-cases';
  if (cat.includes('hat') || cat.includes('glove'))              return 'accessories/hats-gloves';

  // Clothing
  if (cat.includes('outerwear') || cat.includes('jacket') || cat.includes('coat'))
                                                                  return nm.includes('leather') ? `${dept}/outerwear/leather-jackets` : nm.includes('trench') ? `${dept}/outerwear/trench-coats` : nm.includes('puffer') || nm.includes('down') ? `${dept}/outerwear/puffer-down-jackets` : nm.includes('blazer') ? `${dept}/outerwear/blazers` : nm.includes('coat') ? `${dept}/outerwear/coats` : `${dept}/outerwear/jackets`;
  if (cat.includes('blazer'))                                     return `${dept}/outerwear/blazers`;
  if (cat.includes('dress'))                                      return nm.includes('mini') ? 'women/dresses/mini-dresses' : nm.includes('midi') ? 'women/dresses/midi-dresses' : nm.includes('maxi') ? 'women/dresses/maxi-dresses' : nm.includes('evening') || nm.includes('gown') ? 'women/dresses/evening-gowns' : 'women/dresses/midi-dresses';
  if (cat.includes('knitwear') || cat.includes('knit'))          return nm.includes('cardigan') ? `${dept}/knitwear/cardigans` : nm.includes('turtleneck') ? `${dept}/knitwear/turtlenecks` : `${dept}/knitwear/sweaters`;
  if (cat.includes('top') || cat.includes('blouse') || cat.includes('shirt'))
                                                                  return nm.includes('blouse') ? 'women/tops/blouses' : nm.includes('shirt') ? `${dept}/tops/shirts` : nm.includes('sweat') || nm.includes('hoodie') ? `${dept}/tops/sweatshirts-hoodies` : `${dept}/tops/t-shirts`;
  if (cat.includes('trouser') || cat.includes('pant'))           return `${dept}/trousers-shorts/tailored-trousers`;
  if (cat.includes('skirt'))                                      return nm.includes('mini') ? 'women/skirts/mini-skirts' : nm.includes('midi') ? 'women/skirts/midi-skirts' : nm.includes('maxi') ? 'women/skirts/maxi-skirts' : 'women/skirts/midi-skirts';
  if (cat.includes('denim') || cat.includes('jean'))             return `${dept}/jeans-denim/straight-jeans`;
  if (cat.includes('jumpsuit') || cat.includes('playsuit'))      return 'women/jumpsuits-playsuits/full-length-jumpsuits';
  if (cat.includes('swimwear') || cat.includes('bikini'))        return 'women/swimwear/bikinis';

  return dept; // fallback to department root
}

// ────────────────────────────────────────────────────────────
// MAIN
// ────────────────────────────────────────────────────────────
async function main() {
  await seedTaxonomy();
  await seedProducts();
}

main()
  .catch(e => { console.error(e); process.exit(1); })
  .finally(() => prisma.$disconnect());