// lib/validator.ts
// ============================================================
// Zod schemas for youwanto.com — updated for new Prisma schema
// (Category tree, Product facets, ProductVariant, Cart, Auth)
// ============================================================

import { z } from 'zod';
import { formatNumberWithDecimal } from './utils';

// ────────────────────────────────────────────────────────────
// Price helper
// ────────────────────────────────────────────────────────────
const formatPrice = z.string().refine(
  (value) => /^\d+(\.\d{2})?$/.test(formatNumberWithDecimal(Number(value))),
  'Invalid price format. Must be a number with up to two decimal places.'
);

// ────────────────────────────────────────────────────────────
// Product — new schema (with facets, no top-level category string)
// ────────────────────────────────────────────────────────────
export const insertProductSchema = z.object({
  name:         z.string().min(3, 'Name must be at least 3 characters'),
  slug:         z.string().min(3, 'Slug must be at least 3 characters'),
  brand:        z.string().min(1, 'Brand is required'),
  description:  z.string().min(10, 'Description must be at least 10 characters'),
  shortDescription: z.string().optional().nullable(),
  images:       z.array(z.string().url('Invalid image URL')).min(1, 'At least one image is required'),
  imageUrl:     z.string().url().optional().nullable(),

  // Facet arrays
  colors:    z.array(z.string()).default([]),
  sizes:     z.array(z.string()).default([]),
  materials: z.array(z.string()).default([]),
  searchTags:z.array(z.string()).default([]),

  // Enums
  gender:    z.enum(['FEMALE', 'MALE', 'UNISEX']).default('UNISEX'),
  condition: z.enum(['NEW', 'USED', 'REFURBISHED']).default('NEW'),

  // Source tracking
  source:     z.enum(['AWIN', 'OUTNET', 'RAKUTEN']),
  externalId: z.string().min(1, 'External ID is required'),
  merchantId: z.string().optional().nullable(),
  groupId:    z.string().optional().nullable(),
  ean:        z.string().optional().nullable(),
  mpn:        z.string().optional().nullable(),

  // Optional fields kept for backwards compat
  isFeatured: z.boolean().optional(),
  banner:     z.string().nullable().optional(),
});

// ────────────────────────────────────────────────────────────
// ProductVariant — new schema
// ────────────────────────────────────────────────────────────
export const productVariantSchema = z.object({
  externalId: z.string().min(1, 'External ID is required'),
  sku:        z.string().optional().nullable(),
  ean:        z.string().optional().nullable(),
  color:      z.string().optional().nullable(),
  size:       z.string().optional().nullable(),
  material:   z.string().optional().nullable(),

  price:          formatPrice,
  compareAtPrice: formatPrice.optional().nullable(),
  currency:       z.string().length(3, 'Currency must be a 3-letter code'),
  discountPct:    z.number().min(0).max(100).optional().nullable(),

  inStock:   z.boolean().default(true),
  stockQty:  z.coerce.number().min(0).optional().nullable(),
  deepLink:  z.string().url().optional().nullable(),
  imageUrl:  z.string().url().optional().nullable(),
  images:    z.array(z.string().url()).default([]),
});

// ────────────────────────────────────────────────────────────
// Category
// ────────────────────────────────────────────────────────────
export const categorySchema = z.object({
  name:      z.string().min(1, 'Category name is required'),
  slug:      z.string().min(1, 'Slug is required'),
  level:     z.number().int().min(1).max(3),
  path:      z.string().min(1, 'Path is required'),
  sortOrder: z.number().int().default(0),
  parentId:  z.string().optional().nullable(),
});

// ────────────────────────────────────────────────────────────
// RawProduct (unchanged — used by seed)
// ────────────────────────────────────────────────────────────
export const RawProductSchema = z.object({
  source:        z.string(),
  feedBatchId:   z.string().nullable(),
  rawData:       z.record(z.string(), z.any()),
  sku:           z.string(),
  styleCode:     z.string().nullable(),
  productIdFeed: z.string().nullable(),
  ean:           z.string().nullable(),
});

// ────────────────────────────────────────────────────────────
// Auth
// ────────────────────────────────────────────────────────────
export const signInFormSchema = z.object({
  email:    z.string().email('Invalid email address'),
  password: z.string().min(6, 'Password must be at least 6 characters'),
});

export const signUpFormSchema = z
  .object({
    name:            z.string().min(3, 'Name must be at least 3 characters'),
    email:           z.string().email('Invalid email address'),
    password:        z.string().min(6, 'Password must be at least 6 characters'),
    confirmPassword: z.string(),
  })
  .refine((data) => data.password === data.confirmPassword, {
    message: 'Passwords do not match',
    path: ['confirmPassword'],
  });

// ────────────────────────────────────────────────────────────
// Cart
// ────────────────────────────────────────────────────────────
export const cartItemSchema = z.object({
  productId:  z.string().min(1, 'Product is required'),
  variantId:  z.string().optional().nullable(),
  name:       z.string().min(1, 'Product name is required'),
  slug:       z.string().min(1, 'Product slug is required'),
  price:      formatPrice,
  currency:   z.string().length(3, 'Currency must be a 3-letter code'),
  quantity:   z.number().int().nonnegative('Quantity must be a non-negative integer'),
  image:      z.string().min(1, 'Image is required'),
  // optional display helpers
  size:  z.string().optional().nullable(),
  color: z.string().optional().nullable(),
});

export const insertCartSchema = z.object({
  items:          z.array(cartItemSchema),
  itemsPrice:     formatPrice,
  taxPrice:       formatPrice,
  shippingPrice:  formatPrice,
  totalPrice:     formatPrice,
  sessionCartId:  z.string().min(1, 'Session cart ID is required'),
  userId:         z.string().optional().nullable(),
});

// ────────────────────────────────────────────────────────────
// Collection page query params
// ────────────────────────────────────────────────────────────
export const collectionQuerySchema = z.object({
  path:      z.string().min(1),               // e.g. "women/outerwear/jackets"
  colors:    z.array(z.string()).optional(),
  sizes:     z.array(z.string()).optional(),
  materials: z.array(z.string()).optional(),
  brands:    z.array(z.string()).optional(),
  minPrice:  z.coerce.number().optional(),
  maxPrice:  z.coerce.number().optional(),
  inStockOnly: z.boolean().default(false),
  sort:      z.enum(['price_asc', 'price_desc', 'newest']).default('newest'),
  page:      z.coerce.number().int().min(1).default(1),
  limit:     z.coerce.number().int().min(1).max(100).default(24),
});